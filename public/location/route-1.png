<script>
jQuery(function ($) {
	
	
	$(function() {
    datepicker();
});

function datepicker()
{
    try{
        $( ".selecdata" ).datepicker(
            {
                closeText: 'Fechar',
                prevText: '&#xf060;',
                nextText: '&#xf061;',
                currentText: 'Hoje',
                monthNames: ['Janeiro', 'Fevereiro', 'Mar&ccedil;o', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                dayNames: ['Domingo', 'Segunda-feira', 'Ter&ccedil;a-feira', 'Quarta-feira', 'Quinta-feira', 'Sexta-feira', 'S&aacute;bado'],
                dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'S&aacute;b'],
                dayNamesMin: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'S&aacute;b'],
                weekHeader: 'Sem',
                dateFormat: 'dd/mm/yy',
                firstDay: 0,
                isRTL: false,
                showMonthAfterYear: false,
                yearSuffix: '',
                changeMonth: true,
                yearRange: '1900:2018',
                changeYear: true
            });
    }catch(err){}
}  
	
		$(document).ready(function(){
  			$('.selecdata').mask('00/00/0000');
		});	
	
		$('#selcur').change(function() {
			var filename = $('#selcur').val();
			filename = filename.replace(/^C:\\fakepath\\/, "");
			$('#select_file').html("Arquivo Selecionado:" + filename);
		});	
		
		
		$(window).resize(function(){
		imagens();	
		});
		
		$(window).load(function(){
		 imagens();
		 $('#sidegaly').find('img').each(function(){
		  var imgClass = (this.width/this.height > 1) ? 'wide' : 'tall';
		  $(this).addClass(imgClass);
		 });
		 	 
		});
	
	    $('#main-slider').liquidSlider({
		autoSlide: true,
		dynamicArrows: true,
		hoverArrows: false,
		dynamicTabs: false	
		});
	
	$(".mobile-menu").on("click", function(){
		if($(this).hasClass("opened")){
			$("header ul").slideUp();		
			$(this).removeClass("opened");		
		}else{
			$("header ul").slideDown();		
			$(this).addClass("opened");
		}
	});
	
	
	function imagens(){
		 $("#sidegaly .photo img").each(function() {
			if($(this).parent().parent().width() > $(this).parent().parent().height()){			
				$(this).css({
				width: '100%',
				height: 'auto'	
				});
				if($(this).height() < $(this).parent().parent().height()){
					$(this).css({
					height: '100%',
					width: 'auto'	
					});						
				}
			}else{
				$(this).css({
				height: '100%',
				width: 'auto'	
				});	
				if($(this).width() < $(this).parent().parent().width()){
					$(this).css({
					width: '100%',
					height: 'auto'	
					});
				}
			}
        });	
	}	
	
	
});
</script>
